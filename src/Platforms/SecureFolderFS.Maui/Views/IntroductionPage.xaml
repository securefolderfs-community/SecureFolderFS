<ContentPage
    x:Class="SecureFolderFS.Maui.Views.IntroductionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:av="clr-namespace:Xe.AcrylicView;assembly=Xe.AcrylicView"
    xmlns:av2="clr-namespace:Xe.AcrylicView.Controls;assembly=Xe.AcrylicView"
    xmlns:l="clr-namespace:SecureFolderFS.Maui.Localization"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:mi_cupertino="clr-namespace:MauiIcons.Cupertino;assembly=MauiIcons.Cupertino"
    xmlns:mi_material="clr-namespace:MauiIcons.Material;assembly=MauiIcons.Material"
    xmlns:uc="clr-namespace:SecureFolderFS.Maui.UserControls"
    xmlns:ucc="clr-namespace:SecureFolderFS.Maui.UserControls.Common">

    <ContentPage.Resources>
        <uc:IntroductionSlide
            x:Key="Slide0"
            Title="{l:ResourceString Rid=WelcomeTo,
                                     Converter={StaticResource StringInterpolationConverter},
                                     ConverterParameter='none|SecureFolderFS'}"
            Subtitle="{l:ResourceString Rid=OnboardingWelcomeSubtitle}">
            <uc:IntroductionSlide.Slot>
                <Image HeightRequest="300" Source="{AppThemeBinding Light='intro_light_apple_devices.png', Dark='intro_dark_apple_devices.png'}" />
            </uc:IntroductionSlide.Slot>
            <uc:IntroductionSlide.SlotBelow>
                <Label
                    Margin="0,16,0,0"
                    FontSize="10"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    Opacity="0.6">

                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{l:ResourceString Rid=IntroPrefix}" />
                            <Span
                                Text="{l:ResourceString Rid=PrivacyPolicy}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                            Dark={StaticResource PrimaryDarkColor}}"
                                TextDecorations="Underline">
                                <Span.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="PrivacyPolicy_Tapped" />
                                </Span.GestureRecognizers>
                            </Span>
                            <Span Text="{l:ResourceString Rid=IntroMiddle}" />
                            <Span
                                Text="{l:ResourceString Rid=TermsOfService}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                            Dark={StaticResource PrimaryDarkColor}}"
                                TextDecorations="Underline">
                                <Span.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="TermsOfService_Tapped" />
                                </Span.GestureRecognizers>
                            </Span>
                            <Span Text="{l:ResourceString Rid=IntroSuffix}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </uc:IntroductionSlide.SlotBelow>
        </uc:IntroductionSlide>
        <uc:IntroductionSlide
            x:Key="Slide1"
            Title="{l:ResourceString Rid=OnboardingDashboardTitle}"
            Subtitle="{l:ResourceString Rid=OnboardingDashboardSubtitle}">
            <uc:IntroductionSlide.Slot>
                <ucc:MaskedImage
                    Margin="0,0,0,-200"
                    Aspect="AspectFit"
                    HeightRequest="600"
                    SourceFileName="{OnPlatform Android={AppThemeBinding Light='intro_light_iphone_dashboard.png',
                                                                         Dark='intro_dark_iphone_dashboard.png'},
                                                iOS={AppThemeBinding Light='intro_light_iphone_dashboard.png',
                                                                     Dark='intro_dark_iphone_dashboard.png'}}"
                    VerticalOptions="Center"
                    StartPoint="0.5,1"
                    EndPoint="0.5,0.3">
                    <ucc:MaskedImage.Stops>
                        <GradientStop Offset="0.5" Color="Transparent" />
                        <GradientStop Offset="1" Color="Black" />
                    </ucc:MaskedImage.Stops>
                </ucc:MaskedImage>
            </uc:IntroductionSlide.Slot>
        </uc:IntroductionSlide>
        <uc:IntroductionSlide
            x:Key="Slide2"
            Title="{l:ResourceString Rid=OnboardingDataSourcesTitle}"
            Subtitle="{l:ResourceString Rid=OnboardingDataSourcesSubtitle}">
            <uc:IntroductionSlide.Slot>
                <Grid
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="16"
                    HorizontalOptions="Center"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="16"
                    VerticalOptions="Center">
                    <uc:IntroductionIconTile
                        Grid.Row="0"
                        Grid.Column="0"
                        Source="source_network_drive_ftp.png" />
                    <uc:IntroductionIconTile
                        Grid.Row="0"
                        Grid.Column="1"
                        Source="source_webdav.png" />
                    <uc:IntroductionIconTile
                        Grid.Row="0"
                        Grid.Column="2"
                        Source="source_gdrive.png" />
                    <uc:IntroductionIconTile
                        Grid.Row="1"
                        Grid.Column="0"
                        Source="source_dropbox.png" />
                </Grid>
            </uc:IntroductionSlide.Slot>
        </uc:IntroductionSlide>
        <uc:IntroductionSlide x:Key="Slide3" Title="{l:ResourceString Rid=OnboardingEndTitle}">
            <uc:IntroductionSlide.Slot>
                <Grid Margin="0,0,0,64" HorizontalOptions="Center">
                    <Ellipse
                        Fill="{AppThemeBinding Light={StaticResource SecondaryLightColor},
                                               Dark={StaticResource SecondaryDarkColor}}"
                        HeightRequest="140"
                        WidthRequest="140" />

                    <mi:MauiIcon
                        HorizontalOptions="Center"
                        Icon="{mi_material:Material Check}"
                        IconColor="{AppThemeBinding Light='#000000',
                                                    Dark='#FFFFFF'}"
                        IconSize="96"
                        OnPlatforms="Android" />
                    <mi:MauiIcon
                        HorizontalOptions="Center"
                        Icon="{mi_cupertino:Cupertino Checkmark}"
                        IconColor="{AppThemeBinding Light='#000000',
                                                    Dark='#FFFFFF'}"
                        IconSize="96"
                        OnPlatforms="iOS" />
                </Grid>
            </uc:IntroductionSlide.Slot>
        </uc:IntroductionSlide>
    </ContentPage.Resources>

    <Grid>
        <!--  Background  -->
        <Grid
            x:Name="BackgroundView"
            Margin="0,-60,0,-35"
            Opacity="0">
            <Ellipse
                HeightRequest="{OnPlatform Android='1000',
                                           iOS='800'}"
                Opacity="0.8"
                ScaleX="2.5"
                VerticalOptions="Start"
                WidthRequest="550">

                <Ellipse.Fill>
                    <OnPlatform x:TypeArguments="Brush">
                        <On Platform="iOS">
                            <RadialGradientBrush>
                                <GradientStop Offset="0.1" Color="{AppThemeBinding Light={StaticResource PrimaryLightColor}, Dark={StaticResource PrimaryDarkColor}}" />
                                <GradientStop Offset="0.6" Color="#106bbf" />
                                <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource LightTransparentColor}, Dark={StaticResource DarkTransparentColor}}" />
                            </RadialGradientBrush>
                        </On>
                        <On Platform="Android">
                            <RadialGradientBrush>
                                <GradientStop Offset="0.1" Color="{AppThemeBinding Light={StaticResource PrimaryLightColor}, Dark={StaticResource PrimaryDarkColor}}" />
                                <GradientStop Offset="0.4" Color="#106bbf" />
                                <GradientStop Offset="0.7" Color="{AppThemeBinding Light={StaticResource LightTransparentColor}, Dark={StaticResource DarkTransparentColor}}" />
                                <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource LightTransparentColor}, Dark={StaticResource DarkTransparentColor}}" />
                            </RadialGradientBrush>
                        </On>
                    </OnPlatform>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <!--  Foreground  -->
        <OnPlatform x:TypeArguments="Grid">
            <On Platform="iOS">
                <Grid>
                    <av:AcrylicView
                        Margin="0,-70,0,-16"
                        CornerRadius="0"
                        EffectStyle="{AppThemeBinding Dark={av2:EffectStyle Dark},
                                                      Light={av2:EffectStyle Light}}">
                        <Grid
                            x:Name="BlurredForegroundView"
                            Opacity="0"
                            RowDefinitions="*,Auto"
                            RowSpacing="32">
                            <ucc:GalleryView Grid.Row="0" Loaded="GalleryView_Loaded" />
                            <Button
                                Grid.Row="1"
                                Margin="24,0,24,24"
                                Clicked="Continue_Clicked"
                                Loaded="Continue_Loaded"
                                Text="{l:ResourceString Rid=Continue}"
                                VerticalOptions="End" />
                        </Grid>
                    </av:AcrylicView>
                </Grid>
            </On>
            <On Platform="Android">
                <Grid
                    x:Name="ForegroundView"
                    Opacity="0"
                    RowDefinitions="*,Auto"
                    RowSpacing="32">
                    <ucc:GalleryView Grid.Row="0" Loaded="GalleryView_Loaded" />
                    <Button
                        Grid.Row="1"
                        Margin="16,0,16,16"
                        Clicked="Continue_Clicked"
                        Loaded="Continue_Loaded"
                        Text="{l:ResourceString Rid=Continue}"
                        VerticalOptions="End" />
                </Grid>
            </On>
        </OnPlatform>

        <OnPlatform x:TypeArguments="Grid">
            <On Platform="Android">
                <Grid
                    x:Name="SystemNavBarGradient"
                    HeightRequest="140"
                    HorizontalOptions="Fill"
                    Opacity="0"
                    VerticalOptions="Start">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Offset="0" Color="{AppThemeBinding Light={StaticResource PrimaryLightColor}, Dark={StaticResource PrimaryDarkColor}}" />
                            <GradientStop Offset="0.6" Color="{AppThemeBinding Light={StaticResource LightTransparentColor}, Dark={StaticResource DarkTransparentColor}}" />
                        </LinearGradientBrush>
                    </Grid.Background>
                </Grid>
            </On>
        </OnPlatform>
    </Grid>
</ContentPage>
