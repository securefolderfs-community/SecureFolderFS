<md:BaseModalPage
    x:Class="SecureFolderFS.Maui.Views.Modals.Wizard.MainWizardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="using:SecureFolderFS.Maui.Localization"
    xmlns:local="clr-namespace:SecureFolderFS.Maui.Views.Modals.Wizard"
    xmlns:md="clr-namespace:SecureFolderFS.Maui.Views.Modals"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:mi_cupertino="clr-namespace:MauiIcons.Cupertino;assembly=MauiIcons.Cupertino"
    xmlns:mi_material="clr-namespace:MauiIcons.Material;assembly=MauiIcons.Material"
    Title="{Binding ViewModel.Title, Mode=OneWay}"
    x:DataType="local:MainWizardPage"
    CloseCommand="{Binding OverlayViewModel.CancellationCommand, Mode=OneWay}"
    CloseText="{Binding OverlayViewModel.SecondaryText, Mode=OneWay}"
    Shell.PresentationMode="ModalAnimated">

    <md:BaseModalPage.ModalContent>
        <VerticalStackLayout Padding="16,0" Spacing="16">
            <Label
                FontSize="16"
                Opacity="0.6"
                Text="Choose how you want to add a new vault." />

            <VerticalStackLayout Spacing="10">

                <!--  Add Existing  -->
                <Border StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>

                    <!--  Content  -->
                    <Grid
                        Grid.Column="1"
                        Padding="16,14"
                        Background="{StaticResource ThemeElevatedFillPrimaryColorBrush}"
                        ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="14">

                        <Border
                            Grid.Column="0"
                            Background="{StaticResource ThemeSecondaryColorBrush}"
                            HeightRequest="42"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="42">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="11" />
                            </Border.StrokeShape>
                            <Grid>
                                <mi:MauiIcon
                                    HorizontalOptions="Center"
                                    Icon="{mi_material:Material Create}"
                                    IconColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                                Dark={StaticResource PrimaryDarkColor}}"
                                    IconSize="20"
                                    OnPlatforms="Android"
                                    VerticalOptions="Center" />
                                <mi:MauiIcon
                                    HorizontalOptions="Center"
                                    Icon="{mi_cupertino:Cupertino PlusCircle}"
                                    IconColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                                Dark={StaticResource PrimaryDarkColor}}"
                                    IconSize="20"
                                    OnPlatforms="iOS"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="3"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="15"
                                Text="{l:ResourceString Rid=AddExisting}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryContrastingLightColor},
                                                            Dark={StaticResource PrimaryContrastingDarkColor}}" />
                            <Label
                                FontSize="12"
                                Opacity="0.6"
                                Text="{l:ResourceString Rid=AddExistingVaultDescription}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryContrastingLightColor},
                                                            Dark={StaticResource PrimaryContrastingDarkColor}}" />
                        </VerticalStackLayout>

                        <mi:MauiIcon
                            Grid.Column="2"
                            Icon="{mi_material:Material ChevronRight}"
                            IconColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                        Dark={StaticResource PrimaryDarkColor}}"
                            IconSize="18"
                            OnPlatforms="Android"
                            VerticalOptions="Center" />
                        <mi:MauiIcon
                            Grid.Column="2"
                            Icon="{mi_cupertino:Cupertino ChevronRight}"
                            IconColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                        Dark={StaticResource PrimaryDarkColor}}"
                            IconSize="18"
                            OnPlatforms="iOS"
                            VerticalOptions="Center" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Existing_Clicked" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <!--  Create New  -->
                <Border StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <!--  Content  -->
                    <Grid
                        Grid.Column="1"
                        Padding="16,14"
                        Background="{StaticResource ThemeElevatedFillPrimaryColorBrush}"
                        ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="14">

                        <Border
                            Grid.Column="0"
                            HeightRequest="42"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="42">
                            <Border.Background>
                                <SolidColorBrush Color="{AppThemeBinding Light=#E1F5EE, Dark=#085041}" />
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="11" />
                            </Border.StrokeShape>
                            <Grid>
                                <mi:MauiIcon
                                    HorizontalOptions="Center"
                                    Icon="{mi_material:Material CreateNewFolder}"
                                    IconColor="#0F6E56"
                                    IconSize="20"
                                    OnPlatforms="Android"
                                    VerticalOptions="Center" />
                                <mi:MauiIcon
                                    HorizontalOptions="Center"
                                    Icon="{mi_cupertino:Cupertino Pencil}"
                                    IconColor="#0F6E56"
                                    IconSize="20"
                                    OnPlatforms="iOS"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="3"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="15"
                                Text="{l:ResourceString Rid=CreateNew}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryContrastingLightColor},
                                                            Dark={StaticResource PrimaryContrastingDarkColor}}" />
                            <Label
                                FontSize="12"
                                Opacity="0.6"
                                Text="{l:ResourceString Rid=CreateNewVaultDescription}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryContrastingLightColor},
                                                            Dark={StaticResource PrimaryContrastingDarkColor}}" />
                        </VerticalStackLayout>

                        <mi:MauiIcon
                            Grid.Column="2"
                            Icon="{mi_material:Material ChevronRight}"
                            IconColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                        Dark={StaticResource PrimaryDarkColor}}"
                            IconSize="18"
                            OnPlatforms="Android"
                            VerticalOptions="Center" />
                        <mi:MauiIcon
                            Grid.Column="2"
                            Icon="{mi_cupertino:Cupertino ChevronRight}"
                            IconColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                        Dark={StaticResource PrimaryDarkColor}}"
                            IconSize="18"
                            OnPlatforms="iOS"
                            VerticalOptions="Center" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="New_Clicked" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </md:BaseModalPage.ModalContent>
</md:BaseModalPage>
