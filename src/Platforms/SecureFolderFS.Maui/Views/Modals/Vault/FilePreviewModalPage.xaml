<md:BaseModalPage
    x:Class="SecureFolderFS.Maui.Views.Modals.Vault.FilePreviewModalPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="using:SecureFolderFS.Maui.Localization"
    xmlns:local="clr-namespace:SecureFolderFS.Maui.Views.Modals.Vault"
    xmlns:md="clr-namespace:SecureFolderFS.Maui.Views.Modals"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:mi_cupertino="clr-namespace:MauiIcons.Cupertino;assembly=MauiIcons.Cupertino"
    xmlns:mi_material="clr-namespace:MauiIcons.Material;assembly=MauiIcons.Material"
    xmlns:ts="clr-namespace:SecureFolderFS.Maui.TemplateSelectors"
    xmlns:uc="clr-namespace:SecureFolderFS.Maui.UserControls"
    xmlns:ucc="clr-namespace:SecureFolderFS.Maui.UserControls.Common"
    xmlns:vc="clr-namespace:SecureFolderFS.Maui.ValueConverters"
    xmlns:vlc="clr-namespace:LibVLCSharp.MAUI;assembly=LibVLCSharp.MAUI"
    xmlns:vm="clr-namespace:SecureFolderFS.Sdk.ViewModels.Controls.Previewers;assembly=SecureFolderFS.Sdk"
    x:Name="ThisPage"
    x:DataType="local:FilePreviewModalPage"
    IsImmersive="True"
    NavigationPage.HasNavigationBar="False"
    SafeAreaEdges="None">

    <md:BaseModalPage.Resources>
        <vc:BoolToScrollOrientationConverter x:Key="BoolToScrollOrientationConverter" />
        <vc:FileServerWebViewSourceConverter x:Key="FileServerWebViewSourceConverter" />

        <!--  Carousel  -->
        <DataTemplate x:Key="CarouselTemplate" x:DataType="vm:CarouselPreviewerViewModel">
            <ucc:GalleryView
                HeightRequest="400"
                IsDismissible="True"
                SizeChanged="GalleryView_Loaded"
                WidthRequest="300" />
        </DataTemplate>

        <!--  Video  -->
        <DataTemplate x:Key="VideoTemplate" x:DataType="vm:VideoPreviewerViewModel">
            <uc:PanRouter PanUpdatedCommand="{Binding GalleryView.PanUpdatedCommand, Mode=OneWay, Source={x:Reference ThisPage}}" TappedCommand="{Binding ViewModel.ToggleImmersionCommand, Mode=OneWay, Source={x:Reference ThisPage}}">
                <uc:PanRouter.RouterContent>
                    <vlc:MediaPlayerElement Loaded="MediaPlayerElement_Loaded">
                        <vlc:MediaPlayerElement.PlaybackControls>
                            <vlc:PlaybackControls
                                BackgroundColor="Transparent"
                                ControlsPanelStyle="{StaticResource VideoControlsPanelStyle}"
                                ElapsedTimeLabelStyle="{StaticResource VideoElapsedTimeLabelStyle}"
                                Foreground="#FFFFFF"
                                IsAspectRatioButtonVisible="False"
                                IsCastButtonVisible="False"
                                IsLockButtonVisible="False"
                                IsTracksButtonVisible="False"
                                LockButtonStyle="{StaticResource VideoLockButtonStyle}"
                                MainColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                            Dark={StaticResource PrimaryDarkColor}}"
                                PlayPauseButtonStyle="{StaticResource VideoPlayPauseButtonStyle}"
                                RemainingTimeLabelStyle="{StaticResource VideoRemainingTimeLabelStyle}"
                                RewindButtonStyle="{StaticResource VideoRewindButtonStyle}"
                                SeekBarStyle="{StaticResource VideoSeekBarStyle}"
                                SeekButtonStyle="{StaticResource VideoSeekButtonStyle}"
                                UnLockButtonStyle="{StaticResource VideoUnlockButtonStyle}" />
                        </vlc:MediaPlayerElement.PlaybackControls>
                    </vlc:MediaPlayerElement>
                </uc:PanRouter.RouterContent>
            </uc:PanRouter>
        </DataTemplate>

        <!--  Audio  -->
        <DataTemplate x:Key="AudioTemplate" x:DataType="vm:AudioPreviewerViewModel">
            <uc:PanRouter PanUpdatedCommand="{Binding GalleryView.PanUpdatedCommand, Mode=OneWay, Source={x:Reference ThisPage}}" TappedCommand="{Binding ViewModel.ToggleImmersionCommand, Mode=OneWay, Source={x:Reference ThisPage}}">
                <uc:PanRouter.RouterContent>
                    <Grid>
                        <VerticalStackLayout
                            Padding="16"
                            HorizontalOptions="Center"
                            Spacing="24"
                            VerticalOptions="Center">
                            <Grid>
                                <mi:MauiIcon
                                    HorizontalOptions="Center"
                                    Icon="{mi_cupertino:Cupertino Speaker3}"
                                    IconSize="56"
                                    OnPlatforms="iOS" />
                                <mi:MauiIcon
                                    HorizontalOptions="Center"
                                    Icon="{mi_material:Material VolumeUp}"
                                    IconSize="56"
                                    OnPlatforms="Android" />
                            </Grid>

                            <Label
                                FontSize="18"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                Opacity="0.8"
                                Text="{Binding Title, Mode=OneWay}" />
                        </VerticalStackLayout>

                        <vlc:MediaPlayerElement Loaded="MediaPlayerElement_Loaded">
                            <vlc:MediaPlayerElement.PlaybackControls>
                                <vlc:PlaybackControls
                                    BackgroundColor="Transparent"
                                    ControlsPanelStyle="{StaticResource VideoControlsPanelStyle}"
                                    ElapsedTimeLabelStyle="{StaticResource VideoElapsedTimeLabelStyle}"
                                    Foreground="#FFFFFF"
                                    IsAspectRatioButtonVisible="False"
                                    IsCastButtonVisible="False"
                                    IsLockButtonVisible="False"
                                    IsTracksButtonVisible="False"
                                    LockButtonStyle="{StaticResource VideoLockButtonStyle}"
                                    MainColor="{AppThemeBinding Light={StaticResource PrimaryLightColor},
                                                                Dark={StaticResource PrimaryDarkColor}}"
                                    PlayPauseButtonStyle="{StaticResource VideoPlayPauseButtonStyle}"
                                    RemainingTimeLabelStyle="{StaticResource VideoRemainingTimeLabelStyle}"
                                    RewindButtonStyle="{StaticResource VideoRewindButtonStyle}"
                                    SeekBarStyle="{StaticResource VideoSeekBarStyle}"
                                    SeekButtonStyle="{StaticResource VideoSeekButtonStyle}"
                                    UnLockButtonStyle="{StaticResource VideoUnlockButtonStyle}" />
                            </vlc:MediaPlayerElement.PlaybackControls>
                        </vlc:MediaPlayerElement>
                    </Grid>
                </uc:PanRouter.RouterContent>
            </uc:PanRouter>
        </DataTemplate>

        <!--  Image  -->
        <DataTemplate x:Key="ImageTemplate" x:DataType="vm:ImagePreviewerViewModel">
            <ucc:PanPinchContainer PanUpdatedCommand="{Binding GalleryView.PanUpdatedCommand, Mode=OneWay, Source={x:Reference ThisPage}}" TappedCommand="{Binding ViewModel.ToggleImmersionCommand, Mode=OneWay, Source={x:Reference ThisPage}}">
                <Image Source="{Binding Image, Mode=OneWay, Converter={StaticResource ImageToSourceConverter}}" />
            </ucc:PanPinchContainer>
        </DataTemplate>

        <!--  Text  -->
        <DataTemplate x:Key="TextTemplate" x:DataType="vm:TextPreviewerViewModel">
            <Grid>
                <ScrollView
                    Padding="8,16,8,8"
                    HorizontalScrollBarVisibility="Always"
                    IsVisible="{Binding IsProgressing, Mode=OneWay, Converter={StaticResource BoolInvertConverter}}"
                    Orientation="{Binding IsWrappingText, Mode=OneWay, Converter={StaticResource BoolToScrollOrientationConverter}}"
                    VerticalScrollBarVisibility="Always">
                    <Editor
                        AutoSize="TextChanges"
                        Background="{StaticResource ThemeBackgroundFillSecondaryColorBrush}"
                        CursorPosition="{Binding CursorPosition, Mode=TwoWay}"
                        HorizontalOptions="Fill"
                        IsReadOnly="{Binding IsReadOnly, Mode=OneWay}"
                        Placeholder="{l:ResourceString Rid=WriteHere}"
                        Text="{Binding Text, Mode=TwoWay}"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryContrastingLightColor},
                                                    Dark={StaticResource PrimaryContrastingDarkColor}}" />
                </ScrollView>
                <ActivityIndicator
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsProgressing, Mode=OneWay}"
                    IsVisible="{Binding IsProgressing, Mode=OneWay}"
                    VerticalOptions="Center"
                    Color="{OnPlatform iOS={AppThemeBinding Light={StaticResource PrimaryContrastingLightColor},
                                                            Dark={StaticResource PrimaryContrastingDarkColor}}}" />

                <uc:AnimatedRevealLayout
                    Padding="16,10"
                    Background="{StaticResource ThemeElevatedFillPrimaryColorBrush}"
                    HorizontalOptions="Fill"
                    IsShown="{Binding WasModified, Mode=OneWay}"
                    RevealSide="Left"
                    VerticalOptions="End">
                    <uc:AnimatedRevealLayout.RevealContent>
                        <HorizontalStackLayout Spacing="16">
                            <Label
                                FontSize="12"
                                Opacity="0.6"
                                Text="{l:ResourceString Rid=FileModified}" />
                            <BoxView
                                Margin="0,0,16,0"
                                Background="{StaticResource ThemeElevatedFillSecondaryColorBrush}"
                                VerticalOptions="Fill"
                                WidthRequest="1" />
                        </HorizontalStackLayout>
                    </uc:AnimatedRevealLayout.RevealContent>
                    <uc:AnimatedRevealLayout.MainContent>
                        <HorizontalStackLayout Spacing="16">
                            <Label
                                FontSize="12"
                                Opacity="0.6"
                                Text="{Binding CharacterCount, Mode=OneWay, Converter={StaticResource StringInterpolationConverter}, ConverterParameter='inverseMode:LOCALIZE|CharacterCount'}" />
                            <BoxView
                                Background="{StaticResource ThemeElevatedFillSecondaryColorBrush}"
                                VerticalOptions="Fill"
                                WidthRequest="1" />
                            <Label
                                FontSize="12"
                                Opacity="0.6"
                                Text="{Binding CursorPosition, Mode=OneWay, Converter={StaticResource StringInterpolationConverter}, ConverterParameter='inverseMode:LOCALIZE|CursorPosition'}" />
                        </HorizontalStackLayout>
                    </uc:AnimatedRevealLayout.MainContent>
                </uc:AnimatedRevealLayout>
            </Grid>
        </DataTemplate>

        <!--  PDF  -->
        <DataTemplate x:Key="PdfTemplate" x:DataType="vm:PdfPreviewerViewModel">
            <WebView
                Background="Transparent"
                HorizontalOptions="Fill"
                Source="{Binding PdfSource, Mode=OneWay, Converter={StaticResource FileServerWebViewSourceConverter}}"
                VerticalOptions="Fill" />
        </DataTemplate>

        <!--  Archive  -->
        <DataTemplate x:Key="ArchiveTemplate" x:DataType="vm:ArchivePreviewerViewModel">
            <Grid>
                <VerticalStackLayout
                    Padding="16"
                    Spacing="16"
                    VerticalOptions="Center">

                    <!--  Archive Icon  -->
                    <Image
                        HeightRequest="80"
                        HorizontalOptions="Center"
                        Source="{OnPlatform Android='android_archive.png',
                                            iOS='ios_archive.png'}"
                        WidthRequest="80" />

                    <VerticalStackLayout>
                        <!--  Title  -->
                        <Label
                            FontSize="18"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Opacity="0.8"
                            Text="{Binding Title, Mode=OneWay}" />
                        <!--  File Size  -->
                        <Label
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Opacity="0.8"
                            Text="{Binding Size, Mode=OneWay}" />
                    </VerticalStackLayout>

                    <!--  Extract Button  -->
                    <OnPlatform x:TypeArguments="uc:ActivityButton">
                        <On Platform="Android">
                            <uc:ActivityButton
                                ButtonStyle="{StaticResource TransparentButtonStyle}"
                                Command="{Binding ExtractCommand}"
                                HorizontalOptions="Center"
                                IsEnabled="{Binding IsSupported, Mode=OneWay}"
                                IsProgressing="{Binding IsProgressing, Mode=OneWay}"
                                MinimumWidthRequest="128"
                                Text="{l:ResourceString Rid=Extract}" />
                        </On>
                        <On Platform="iOS">
                            <uc:ActivityButton
                                ButtonStyle="{StaticResource NoBackgroundButtonStyle}"
                                Command="{Binding ExtractCommand}"
                                HorizontalOptions="Center"
                                IsEnabled="{Binding IsSupported, Mode=OneWay}"
                                IsProgressing="{Binding IsProgressing, Mode=OneWay}"
                                Text="{l:ResourceString Rid=Extract}" />
                        </On>
                    </OnPlatform>

                    <!--  Unsupported Format Notice  -->
                    <Label
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding IsSupported, Mode=OneWay, Converter={StaticResource BoolInvertConverter}}"
                        Opacity="0.8"
                        Text="{l:ResourceString Rid=ArchiveFormatNotSupported}" />
                </VerticalStackLayout>
            </Grid>
        </DataTemplate>

        <!--  Fallback  -->
        <DataTemplate x:Key="FallbackTemplate" x:DataType="vm:FallbackPreviewerViewModel">
            <VerticalStackLayout
                Padding="16"
                Spacing="16"
                VerticalOptions="Center">
                <Grid HorizontalOptions="Center">
                    <mi:MauiIcon Icon="{mi_material:Material Icon=Description, IconSize=50, IconColor={AppThemeBinding Light={StaticResource PrimaryContrastingLightColor}, Dark={StaticResource PrimaryContrastingDarkColor}}}" OnPlatforms="Android" />
                    <mi:MauiIcon Icon="{mi_cupertino:Cupertino Icon=Doc, IconSize=50, IconColor={AppThemeBinding Light={StaticResource PrimaryContrastingLightColor}, Dark={StaticResource PrimaryContrastingDarkColor}}}" OnPlatforms="iOS" />
                </Grid>

                <Label
                    FontSize="20"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="{Binding Title, Mode=OneWay}" />
                <Label
                    HorizontalOptions="Center"
                    Opacity="0.8"
                    Text="{l:ResourceString Rid=NoPreviewAvailable}" />
            </VerticalStackLayout>
        </DataTemplate>
    </md:BaseModalPage.Resources>

    <md:BaseModalPage.ModalContent>
        <uc:CommandBarControl
            Title="{Binding ViewModel.PreviewerViewModel.Title, Mode=OneWay}"
            Closed="Closed_Clicked"
            IsImmersed="{Binding ViewModel.IsImmersed, Mode=OneWay}"
            IsToolbarOnTop="{Binding ViewModel.PreviewerViewModel.IsToolbarOnTop, Mode=OneWay}"
            PropertiesCommand="{Binding ViewModel.OpenPropertiesCommand}"
            ShareCommand="{Binding ViewModel.ShareCommand}">
            <uc:CommandBarControl.InnerContent>
                <uc:ContentPresentation
                    x:Name="Presentation"
                    Presentation="{Binding ViewModel.PreviewerViewModel, Mode=OneWay}"
                    ZIndex="1">
                    <uc:ContentPresentation.TemplateSelector>
                        <ts:PreviewerTemplateSelector
                            ArchiveTemplate="{StaticResource ArchiveTemplate}"
                            AudioTemplate="{StaticResource AudioTemplate}"
                            CarouselTemplate="{StaticResource CarouselTemplate}"
                            FallbackTemplate="{StaticResource FallbackTemplate}"
                            ImageTemplate="{StaticResource ImageTemplate}"
                            PdfTemplate="{StaticResource PdfTemplate}"
                            TextTemplate="{StaticResource TextTemplate}"
                            VideoTemplate="{StaticResource VideoTemplate}" />
                    </uc:ContentPresentation.TemplateSelector>
                </uc:ContentPresentation>
            </uc:CommandBarControl.InnerContent>
        </uc:CommandBarControl>
    </md:BaseModalPage.ModalContent>
</md:BaseModalPage>
