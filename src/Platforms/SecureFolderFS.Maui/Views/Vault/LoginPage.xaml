<ContentPage
    x:Class="SecureFolderFS.Maui.Views.Vault.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="using:SecureFolderFS.Maui.Localization"
    xmlns:local="clr-namespace:SecureFolderFS.Maui.Views.Vault"
    xmlns:uc="clr-namespace:SecureFolderFS.Maui.UserControls"
    xmlns:vc="clr-namespace:SecureFolderFS.Maui.ValueConverters"
    Title="{Binding ViewModel.VaultViewModel.Title, Mode=OneWay}"
    x:DataType="local:LoginPage">

    <ContentPage.Resources>
        <vc:TypeNameBoolConverter x:Key="TypeNameBoolConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <Grid
            Padding="20,24"
            RowDefinitions="Auto,*,Auto"
            RowSpacing="32"
            VerticalOptions="Fill">

            <!--  Title  -->
            <VerticalStackLayout Grid.Row="0">
                <Label
                    Margin="2,0,0,0"
                    CharacterSpacing="1"
                    FontSize="12"
                    Opacity="0.6"
                    Text="{l:ResourceString Rid=Vault}"
                    TextTransform="Uppercase" />
                <Label
                    FontAttributes="Bold"
                    FontSize="42"
                    LineBreakMode="TailTruncation"
                    Text="{Binding ViewModel.Title, Mode=OneWay}" />

                <HorizontalStackLayout Margin="2,4,0,0" Spacing="8">
                    <Ellipse
                        Fill="Red"
                        HeightRequest="12"
                        WidthRequest="12" />
                    <Label
                        CharacterSpacing="1"
                        FontSize="12"
                        Opacity="0.6"
                        Text="{l:ResourceString Rid=VaultLocked}"
                        TextTransform="Uppercase" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!--  Vault info  -->
            <Border
                Grid.Row="1"
                Background="#F4F4F4"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="*,Auto,*">

                    <!--  Top Row  -->
                    <VerticalStackLayout
                        Grid.Row="0"
                        Grid.Column="0"
                        Padding="16"
                        Spacing="4">
                        <Label
                            FontSize="12"
                            Opacity="0.6"
                            Text="Last access"
                            TextTransform="Uppercase" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            Text="2d ago" />

                        <Label
                            FontSize="12"
                            Opacity="0.8"
                            Text="Apr 20, 10:10PM" />
                    </VerticalStackLayout>

                    <BoxView
                        Grid.Row="0"
                        Grid.Column="1"
                        VerticalOptions="Fill"
                        WidthRequest="1"
                        Color="#E1E1E1" />

                    <VerticalStackLayout
                        Grid.Row="0"
                        Grid.Column="2"
                        Padding="16"
                        Spacing="4">
                        <Label
                            FontSize="12"
                            Opacity="0.6"
                            Text="Vault version"
                            TextTransform="Uppercase" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            Text="V4" />

                        <Label
                            FontSize="12"
                            Opacity="0.8"
                            Text="Latest support" />
                    </VerticalStackLayout>

                    <!--  Separator  -->
                    <BoxView
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        HeightRequest="1"
                        HorizontalOptions="Fill"
                        Color="#E1E1E1" />

                    <!--  Bottom Row  -->
                    <VerticalStackLayout
                        Grid.Row="2"
                        Grid.Column="0"
                        Padding="16"
                        Spacing="16">
                        <Label
                            FontSize="12"
                            Opacity="0.6"
                            Text="Read-only"
                            TextTransform="Uppercase" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="12"
                                LineBreakMode="WordWrap"
                                Text="Unlock as read-only" />
                            <Switch Grid.Column="1" IsToggled="{Binding ViewModel.IsReadOnly, Mode=TwoWay}" />
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView
                        Grid.Row="2"
                        Grid.Column="1"
                        VerticalOptions="Fill"
                        WidthRequest="1"
                        Color="#E1E1E1" />

                    <VerticalStackLayout
                        Grid.Row="2"
                        Grid.Column="2"
                        Padding="16"
                        Spacing="16">
                        <Label
                            FontSize="12"
                            Opacity="0.6"
                            Text="Credentials"
                            TextTransform="Uppercase" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="12"
                                LineBreakMode="WordWrap"
                                Text="Save credentials" />
                            <Switch Grid.Column="1" />
                        </Grid>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <!--  Remote connection progress indicator  -->
            <ActivityIndicator
                Grid.Row="1"
                Margin="0,0,0,16"
                HorizontalOptions="Center"
                IsRunning="{Binding ViewModel.IsProgressing, Mode=OneWay}"
                IsVisible="{Binding ViewModel.LoginViewModel, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                Opacity="{Binding ViewModel.IsProgressing, Mode=OneWay, Converter={StaticResource BoolOpacityConverter}}"
                VerticalOptions="Center" />

            <!--  Login  -->
            <uc:VaultLocatorControl
                Grid.Row="2"
                CancelConnectionCommand="{Binding ViewModel.CancelConnectionCommand, Mode=OneWay}"
                ConnectCommand="{Binding ViewModel.ConnectToVaultCommand, Mode=OneWay}"
                IsConnected="{Binding ViewModel.LoginViewModel, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                IsRunning="{Binding ViewModel.ConnectToVaultCommand.IsRunning, Mode=OneWay}">
                <uc:VaultLocatorControl.LoginView>
                    <VerticalStackLayout IsVisible="{Binding ViewModel.IsProgressing, Mode=OneWay, Converter={StaticResource BoolInvertConverter}}" Spacing="8">
                        <uc:LoginControl CurrentViewModel="{Binding ViewModel.LoginViewModel.CurrentViewModel, Mode=OneWay}" ProvideContinuationButton="True" />
                        <Button
                            Command="{Binding ViewModel.LoginViewModel.RecoverAccessCommand}"
                            HorizontalOptions="{OnPlatform Android={LayoutOptions Alignment=Fill},
                                                           iOS={LayoutOptions Alignment=Center}}"
                            IsVisible="{Binding ViewModel.LoginViewModel.CurrentViewModel, Mode=OneWay, Converter={StaticResource TypeNameBoolConverter}, ConverterParameter='MigrationViewModel,ErrorViewModel|invert'}"
                            Style="{OnPlatform Android={StaticResource TransparentButtonStyle},
                                               iOS={StaticResource NoBackgroundButtonStyle}}"
                            Text="{l:ResourceString Rid=RecoverAccess}" />
                    </VerticalStackLayout>
                </uc:VaultLocatorControl.LoginView>
            </uc:VaultLocatorControl>
        </Grid>
    </ScrollView>
</ContentPage>
