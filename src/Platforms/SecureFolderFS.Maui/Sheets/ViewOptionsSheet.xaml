<btsh:BottomSheet
    x:Class="SecureFolderFS.Maui.Sheets.ViewOptionsSheet"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:btsh="http://pluginmauibottomsheet.com"
    xmlns:l="using:SecureFolderFS.Maui.Localization"
    xmlns:scm="http://plugin.segmentedControl.maui"
    xmlns:ucc="clr-namespace:SecureFolderFS.Maui.UserControls.Common"
    xmlns:uco="clr-namespace:SecureFolderFS.Maui.UserControls.Options"
    xmlns:vm="clr-namespace:SecureFolderFS.Sdk.ViewModels.Controls.Components;assembly=SecureFolderFS.Sdk"
    x:Name="ThisSheet"
    Background="{StaticResource ThemeBackgroundFillSecondaryColorBrush}"
    BindingContext="{x:Reference ThisSheet}"
    HasHandle="True"
    IsCancelable="True"
    IsModal="True"
    States="Medium">

    <btsh:BottomSheet.Content>
        <btsh:BottomSheetContent>
            <btsh:BottomSheetContent.ContentTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="16,32" Spacing="16">
                        <uco:OptionsContainer Title="{l:ResourceString Rid=ViewOptions}">
                            <uco:OptionsContainer.InnerContent>
                                <VerticalStackLayout>
                                    <uco:OptionsControl Title="{l:ResourceString Rid=SortBy}">
                                        <uco:OptionsControl.Slot>
                                            <ucc:ModernPicker
                                                BindingContext="{x:Reference ThisSheet}"
                                                HorizontalTextAlignment="End"
                                                IsTransparent="True"
                                                ItemDisplayBinding="{Binding Title, Mode=OneWay, x:DataType={x:Type vm:PickerOptionViewModel}}"
                                                ItemsSource="{Binding ViewModel.SortOptions, Mode=OneWay}"
                                                MinimumWidthRequest="120"
                                                SelectedItem="{Binding ViewModel.CurrentSortOption, Mode=TwoWay}" />
                                        </uco:OptionsControl.Slot>
                                    </uco:OptionsControl>
                                    <uco:OptionsControl Title="{l:ResourceString Rid=ItemLayout}" IsSeparatorVisible="False">
                                        <uco:OptionsControl.Slot>
                                            <ucc:ModernPicker
                                                BindingContext="{x:Reference ThisSheet}"
                                                HorizontalTextAlignment="End"
                                                IsTransparent="True"
                                                ItemDisplayBinding="{Binding Title, Mode=OneWay, x:DataType={x:Type vm:PickerOptionViewModel}}"
                                                ItemsSource="{Binding ViewModel.ViewOptions, Mode=OneWay}"
                                                MinimumWidthRequest="120"
                                                SelectedItem="{Binding ViewModel.CurrentViewOption, Mode=TwoWay}" />
                                        </uco:OptionsControl.Slot>
                                    </uco:OptionsControl>
                                </VerticalStackLayout>
                            </uco:OptionsContainer.InnerContent>
                        </uco:OptionsContainer>
                        <uco:OptionsContainer
                            Title="{l:ResourceString Rid=SizeOptions}"
                            IsTransparent="True"
                            IsVisible="{Binding ViewModel.AreSizeOptionsAvailable, Mode=OneWay, FallbackValue={x:Boolean False}}">
                            <uco:OptionsContainer.InnerContent>
                                <OnPlatform x:TypeArguments="View">
                                    <On Platform="iOS">
                                        <scm:SegmentedControl
                                            x:Name="SizeSegments"
                                            Background="Transparent"
                                            HorizontalOptions="Fill"
                                            Loaded="SizeSegments_Loaded"
                                            SelectedIndexChanged="SizeSegments_SelectedIndexChanged"
                                            SelectedTextColor="{AppThemeBinding Light={StaticResource PrimaryContrastingLightColor},
                                                                                Dark={StaticResource PrimaryContrastingDarkColor}}"
                                            TextColor="{AppThemeBinding Light={StaticResource PrimaryContrastingLightColor},
                                                                        Dark={StaticResource PrimaryContrastingDarkColor}}"
                                            TintColor="{AppThemeBinding Light={StaticResource ShimFillSecondaryLightColor},
                                                                        Dark={StaticResource ShimFillSecondaryDarkColor}}">
                                            <scm:SegmentedControlOption Text="{l:ResourceString Rid=SmallSize}" />
                                            <scm:SegmentedControlOption Text="{l:ResourceString Rid=MediumSize}" />
                                            <scm:SegmentedControlOption Text="{l:ResourceString Rid=LargeSize}" />
                                        </scm:SegmentedControl>
                                    </On>
                                    <On Platform="Android">
                                        <HorizontalStackLayout
                                            x:Name="SizeSegmentsAndroid"
                                            HorizontalOptions="Fill"
                                            Loaded="SizeSegmentsAndroid_Loaded"
                                            Spacing="8" />
                                    </On>
                                </OnPlatform>
                            </uco:OptionsContainer.InnerContent>
                        </uco:OptionsContainer>
                    </VerticalStackLayout>
                </DataTemplate>
            </btsh:BottomSheetContent.ContentTemplate>
        </btsh:BottomSheetContent>
    </btsh:BottomSheet.Content>
</btsh:BottomSheet>
