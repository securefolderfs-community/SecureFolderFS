<UserControl
    x:Class="SecureFolderFS.Uno.UserControls.TitleBarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:SecureFolderFS.Uno.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Canvas.ZIndex="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--  Drag region  -->
        <Border
            x:Name="DragRegion"
            Grid.Column="0"
            Height="32"
            Padding="16,6"
            x:FieldModifier="public"
            IsHitTestVisible="True"
            IsTabStop="False">

            <StackPanel
                x:Name="TitlePanel"
                HorizontalAlignment="Left"
                x:FieldModifier="public"
                Orientation="Horizontal"
                Spacing="6">

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Text="{x:Bind PrimaryTitle, Mode=OneWay}" />
                <TextBlock
                    x:Name="SecondaryTitleText"
                    Margin="0,0,0,2"
                    VerticalAlignment="Bottom"
                    x:Load="{x:Bind SecondaryTitle, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                    CharacterSpacing="32"
                    FontSize="9"
                    FontWeight="Thin"
                    Opacity="0.8"
                    Text="{x:Bind SecondaryTitle, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <!--  Window caption buttons, shown on platforms where the OS does not paint them  -->
        <StackPanel
            x:Name="WindowButtons"
            Grid.Column="1"
            VerticalAlignment="Top"
            x:FieldModifier="public"
            x:Load="{x:Bind IsWindowButtonsVisible, Mode=OneWay}"
            Loaded="WindowButtons_Loaded"
            Orientation="Horizontal">

            <Button
                Width="46"
                Height="32"
                AutomationProperties.Name="{l:ResourceString Rid=Minimize}"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Click="MinimizeButton_Click"
                CornerRadius="0">
                <FontIcon FontSize="10" Glyph="&#xE921;" />
            </Button>
            <Button
                Width="46"
                Height="32"
                AutomationProperties.Name="{l:ResourceString Rid=Maximize}"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Click="MaximizeButton_Click"
                CornerRadius="0">
                <FontIcon
                    x:Name="MaximizeRestoreIcon"
                    FontSize="10"
                    Glyph="&#xE922;" />
            </Button>
            <Button
                Width="46"
                Height="32"
                AutomationProperties.Name="{l:ResourceString Rid=Close}"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Click="CloseButton_Click"
                CornerRadius="0">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C42B1C" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E5C42B1C" />
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                </Button.Resources>
                <FontIcon FontSize="10" Glyph="&#xE8BB;" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
