<UserControl
    x:Class="SecureFolderFS.Uno.UserControls.Introduction.AuthenticationSlide"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:SecureFolderFS.Uno.Localization"
    xmlns:local="using:SecureFolderFS.Uno.UserControls.Introduction"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <local:FeatureSlide Title="{l:ResourceString Rid=OnboardingAuthenticationTitle}" Description="{l:ResourceString Rid=OnboardingAuthenticationSubtitle}">
        <local:FeatureSlide.LeftSlot>
            <Border Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid x:Name="DiagramGrid" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!--  S-curve path - its geometry is computed in code-behind from the
                          actual icon positions so the connection points always line up  -->
                    <Path
                        x:Name="AuthenticationPath"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Opacity="0"
                        Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                        StrokeDashArray="4 4"
                        StrokeThickness="1.5" />

                    <!--  Icons - render second, on top of the path  -->
                    <Grid x:Name="IconsGrid" SizeChanged="IconsGrid_SizeChanged">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Password (left)  -->
                        <Border
                            x:Name="PasswordBorder"
                            Grid.Row="0"
                            Width="80"
                            Height="80"
                            Margin="0,0,120,16"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="40"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.4" ScaleY="0.4" />
                            </Border.RenderTransform>
                            <FontIcon FontSize="36" Glyph="&#xE8AC;" />
                        </Border>

                        <!--  Device Link (right)  -->
                        <Border
                            x:Name="DeviceLinkBorder"
                            Grid.Row="1"
                            Width="80"
                            Height="80"
                            Margin="120,0,0,16"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="40"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.4" ScaleY="0.4" />
                            </Border.RenderTransform>
                            <Image
                                Width="48"
                                Height="48"
                                Style="{ThemeResource AuthDeviceLinkImage}" />
                        </Border>

                        <!--  YubiKey (left)  -->
                        <Border
                            x:Name="YubiKeyBorder"
                            Grid.Row="2"
                            Width="80"
                            Height="80"
                            Margin="0,0,120,16"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="40"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.4" ScaleY="0.4" />
                            </Border.RenderTransform>
                            <Image
                                Width="48"
                                Height="48"
                                Style="{ThemeResource AuthYubiKeyImage}" />
                        </Border>

                        <!--  Key File (right)  -->
                        <Border
                            x:Name="KeyFileBorder"
                            Grid.Row="3"
                            Width="80"
                            Height="80"
                            Margin="120,0,0,0"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="40"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.4" ScaleY="0.4" />
                            </Border.RenderTransform>
                            <FontIcon FontSize="36" Glyph="&#xE8D7;" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </local:FeatureSlide.LeftSlot>
    </local:FeatureSlide>
</UserControl>
