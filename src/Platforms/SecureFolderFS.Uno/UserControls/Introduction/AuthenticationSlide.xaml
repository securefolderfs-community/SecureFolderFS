<UserControl
    x:Class="SecureFolderFS.Uno.UserControls.Introduction.AuthenticationSlide"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:SecureFolderFS.Uno.Localization"
    xmlns:local="using:SecureFolderFS.Uno.UserControls.Introduction"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <local:FeatureSlide Title="{l:ResourceString Rid=OnboardingAuthenticationTitle}" Description="{l:ResourceString Rid=OnboardingAuthenticationSubtitle}">
        <local:FeatureSlide.LeftSlot>
            <Border Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!--  S-curve path - renders first, behind icons  -->
                    <Path
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.25"
                        Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                        StrokeDashArray="4 4"
                        StrokeThickness="1.5">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="40,40">
                                    <BezierSegment
                                        Point1="40,100"
                                        Point2="160,80"
                                        Point3="160,136" />
                                    <BezierSegment
                                        Point1="160,192"
                                        Point2="40,212"
                                        Point3="40,232" />
                                    <BezierSegment
                                        Point1="40,292"
                                        Point2="160,308"
                                        Point3="160,328" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!--  Icons - render second, on top of path  -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Password (left)  -->
                        <Border
                            Grid.Row="0"
                            Width="80"
                            Height="80"
                            Margin="0,0,120,16"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="40">
                            <FontIcon FontSize="36" Glyph="&#xE8AC;" />
                        </Border>

                        <!--  Device Link (right)  -->
                        <Border
                            Grid.Row="1"
                            Width="80"
                            Height="80"
                            Margin="120,0,0,16"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="40">
                            <Image
                                Width="48"
                                Height="48"
                                Style="{ThemeResource AuthDeviceLinkImage}" />
                        </Border>

                        <!--  YubiKey (left)  -->
                        <Border
                            Grid.Row="2"
                            Width="80"
                            Height="80"
                            Margin="0,0,120,16"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="40">
                            <Image
                                Width="48"
                                Height="48"
                                Style="{ThemeResource AuthYubiKeyImage}" />
                        </Border>

                        <!--  Key File (right)  -->
                        <Border
                            Grid.Row="3"
                            Width="80"
                            Height="80"
                            Margin="120,0,0,0"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="40">
                            <FontIcon FontSize="36" Glyph="&#xE8D7;" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </local:FeatureSlide.LeftSlot>
    </local:FeatureSlide>
</UserControl>
