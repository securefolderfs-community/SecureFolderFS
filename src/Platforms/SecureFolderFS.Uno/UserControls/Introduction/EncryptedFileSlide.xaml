<UserControl
    x:Class="SecureFolderFS.Uno.UserControls.Introduction.EncryptedFileSlide"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:SecureFolderFS.Uno.Localization"
    xmlns:local="using:SecureFolderFS.Uno.UserControls.Introduction"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:skia="using:SkiaSharp.Views.Windows"
    mc:Ignorable="d">

    <local:FeatureSlide Title="{l:ResourceString Rid=OnboardingEncryptionTitle}" Description="{l:ResourceString Rid=OnboardingEncryptionSubtitle}">
        <local:FeatureSlide.LeftSlot>
            <Grid
                x:Name="SlotGrid"
                PointerEntered="SlotGrid_PointerEntered"
                PointerExited="SlotGrid_PointerExited"
                PointerMoved="SlotGrid_PointerMoved">
                <skia:SKXamlCanvas
                    x:Name="SkiaCanvas"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    PaintSurface="SkiaCanvas_PaintSurface" />
            </Grid>
        </local:FeatureSlide.LeftSlot>
    </local:FeatureSlide>
</UserControl>
