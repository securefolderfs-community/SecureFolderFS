<UserControl
    x:Class="SecureFolderFS.Uno.UserControls.FeatureTile"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Padding="12,10"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="{ThemeResource ControlCornerRadius}">
        <StackPanel
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="12">
            <FontIcon
                x:Name="TileIcon"
                VerticalAlignment="Center"
                FontSize="18"
                Foreground="#0f80d6"
                Glyph="{x:Bind Glyph, Mode=OneWay}" />
            <StackPanel VerticalAlignment="Center" Spacing="1">
                <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="{x:Bind Description, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
