<Page
    x:Class="SecureFolderFS.Uno.Views.Settings.AccountsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:SecureFolderFS.Uno.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="using:SecureFolderFS.Uno.UserControls"
    xmlns:vmc="using:SecureFolderFS.Sdk.ViewModels.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <!--  Banner  -->
            <RowDefinition Height="Auto" />
            <!--  Account List  -->
            <RowDefinition />
        </Grid.RowDefinitions>

        <!--  Banner  -->
        <uc:BannerControl Grid.Row="0">
            <uc:BannerControl.LeftSide>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="{l:ResourceString Rid=Accounts}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="11"
                        Opacity="0.8"
                        Text="Manage your accounts" />
                </StackPanel>
            </uc:BannerControl.LeftSide>
        </uc:BannerControl>

        <!--  Empty state  -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="{x:Bind ViewModel.Accounts.Count, Mode=OneWay, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter='invert'}">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="32"
                Glyph="&#xE77B;"
                Opacity="0.6" />
            <TextBlock
                HorizontalAlignment="Center"
                Opacity="0.6"
                Text="No accounts have been added yet." />
        </StackPanel>

        <!--  Account List  -->
        <ListView
            Grid.Row="1"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.Accounts.Count, Mode=OneWay, Converter={StaticResource CountToVisibilityConverter}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vmc:AccountItemViewModel">
                    <Grid Margin="0,4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Account icon  -->
                        <Image
                            Grid.Column="0"
                            Width="24"
                            Height="24"
                            Source="{x:Bind Icon, Converter={StaticResource ImageToSourceConverter}}"
                            Visibility="{x:Bind Icon, Converter={StaticResource NullToVisibilityConverter}}" />

                        <!--  Account details  -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title, Mode=OneWay}" />
                            <TextBlock
                                FontSize="11"
                                Opacity="0.6"
                                Text="{x:Bind Subtitle, Mode=OneWay}"
                                Visibility="{x:Bind Subtitle, Converter={StaticResource NullToVisibilityConverter}}" />
                        </StackPanel>

                        <!--  Remove  -->
                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Command="{x:Bind RemoveCommand, Mode=OneWay}"
                            Content="{l:ResourceString Rid=Remove}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
