<Page
    x:Class="SecureFolderFS.Uno.Views.VaultWizard.SummaryWizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animvis="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    Width="464"
    mc:Ignorable="d not_win">

    <Grid Margin="0,8,0,0" RowSpacing="32">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Center"
            Orientation="Vertical"
            Spacing="8">
            <Grid Width="32" Height="32">
                <!--  Success indicator  -->
                <Grid Visibility="{x:Bind ViewModel.IsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter='invert'}">
                    <Ellipse Margin="0,-4,0,2" Fill="LimeGreen" />
                    <not_win:FontIcon FontSize="18" Glyph="&#xE73E;" />
                    <win:AnimatedVisualPlayer
                        x:Name="VisualPlayer"
                        AutoPlay="False"
                        Loaded="VisualPlayer_Loaded">
                        <AnimatedVisualPlayer.Source>
                            <animvis:AnimatedAcceptVisualSource x:Name="CheckVisualSource" />
                        </AnimatedVisualPlayer.Source>
                    </win:AnimatedVisualPlayer>
                </Grid>

                <!--  Error indicator  -->
                <FontIcon
                    FontSize="24"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Glyph="&#xE7BA;"
                    Visibility="{x:Bind ViewModel.IsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
            <TextBlock
                MaxWidth="400"
                HorizontalAlignment="Center"
                FontSize="20"
                HorizontalTextAlignment="Center"
                Text="{x:Bind ViewModel.Message, Mode=OneWay}"
                TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock
            Grid.Row="1"
            HorizontalAlignment="Center"
            Opacity="0.8"
            Text="{x:Bind ViewModel.VaultName, Mode=OneWay}"
            TextTrimming="CharacterEllipsis"
            ToolTipService.ToolTip="{x:Bind ViewModel.VaultName, Mode=OneWay}" />
    </Grid>
</Page>
