<ContentDialog
    x:Class="SecureFolderFS.Uno.Dialogs.RestorationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:h="using:SecureFolderFS.Uno.Helpers"
    xmlns:l="using:SecureFolderFS.Uno.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="using:SecureFolderFS.Uno.UserControls"
    Title="{x:Bind ViewModel.Title, Mode=OneWay}"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    CloseButtonText="{l:ResourceString Rid=Cancel}"
    Closing="ContentDialog_Closing"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    PrimaryButtonText="{l:ResourceString Rid=RestoreVault}"
    RequestedTheme="{x:Bind h:UnoThemeHelper.Instance.CurrentElementTheme, Mode=OneWay}"
    Style="{ThemeResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <StackPanel Spacing="32">
        <StackPanel Spacing="8">
            <InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Important configuration files are corrupted and need to be restored." />

            <TextBlock
                Opacity="0.6"
                Text="SecureFolderFS will try to regenerate configuration files based on information from your encrypted data. You will need to reset your credentials after restoring the vault."
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <uc:RecoveryControl PasteRecoveryKeyCommand="{x:Bind ViewModel.PasteRecoveryKeyCommand, Mode=OneWay}" RecoveryKey="{x:Bind ViewModel.RecoveryKey, Mode=TwoWay}" />
    </StackPanel>
</ContentDialog>
